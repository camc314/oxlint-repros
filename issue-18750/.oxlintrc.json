{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "/node_modules",
    "/*.{js,ts}"
  ],
  "plugins": [
    "eslint",
    "oxc",
    "typescript",
    "import",
    "promise",
    "unicorn"
  ],
  "categories": {
    "correctness": "off"
  },
  "rules": {
    "promise/valid-params": "error",
    "promise/prefer-await-to-then": "error",
  }
}